
<style>
  .reviews-section-{{ section.id }} {
    padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media (min-width: 768px) {
    .reviews-section-{{ section.id }} {
      padding: {{ section.settings.padding_top_desktop }}px {{ section.settings.padding_horizontal_desktop }}px {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .reviews-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
  }

  .reviews-header-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: {{ section.settings.header_bottom_margin }}px;
  }

  @media (min-width: 768px) {
    .reviews-header-{{ section.id }} {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .reviews-header-content-{{ section.id }} {
    flex: 1;
  }

  .reviews-header-{{ section.id }} h2 {
    font-size: {{ section.settings.heading_font_size_mobile }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 {{ section.settings.heading_bottom_margin }}px 0;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .reviews-header-{{ section.id }} h2 {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
  }

  .reviews-header-{{ section.id }} p {
    font-size: {{ section.settings.description_font_size_mobile }}px;
    color: {{ section.settings.description_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .reviews-header-{{ section.id }} p {
      font-size: {{ section.settings.description_font_size_desktop }}px;
    }
  }

  .reviews-navigation-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .reviews-counter-{{ section.id }} {
    font-size: {{ section.settings.counter_font_size }}px;
    color: {{ section.settings.counter_color }};
    font-weight: 500;
  }

  .reviews-nav-buttons-{{ section.id }} {
    display: flex;
    gap: 10px;
  }

  .reviews-nav-btn-{{ section.id }} {
    width: {{ section.settings.nav_button_size }}px;
    height: {{ section.settings.nav_button_size }}px;
    border-radius: {{ section.settings.nav_button_radius }}px;
    border: {{ section.settings.nav_button_border_width }}px solid {{ section.settings.nav_button_border_color }};
    background-color: {{ section.settings.nav_button_bg }};
    color: {{ section.settings.nav_button_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .reviews-nav-btn-{{ section.id }}:hover {
    background-color: {{ section.settings.nav_button_hover_bg }};
    color: {{ section.settings.nav_button_hover_color }};
    border-color: {{ section.settings.nav_button_hover_border }};
  }

  .reviews-nav-btn-{{ section.id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .reviews-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: {{ section.settings.card_gap_mobile }}px;
  }

  @media (min-width: 768px) {
    .reviews-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
      gap: {{ section.settings.card_gap_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    .reviews-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: {{ section.settings.card_gap_desktop }}px;
    }
  }

  .reviews-carousel-{{ section.id }} {
    position: relative;
    overflow: hidden;
  }

  .reviews-carousel-track-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.card_gap_desktop }}px;
    transition: transform 0.5s ease;
  }

  .review-card-{{ section.id }} {
    background-color: {{ section.settings.card_bg_color }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    transition: all 0.3s ease;
  }

  {% if section.settings.layout_type == 'carousel' %}
  .review-card-{{ section.id }} {
    min-width: calc((100% - ({{ section.settings.columns_mobile }} - 1) * {{ section.settings.card_gap_mobile }}px) / {{ section.settings.columns_mobile }});
  }

  @media (min-width: 768px) {
    .review-card-{{ section.id }} {
      min-width: calc((100% - ({{ section.settings.columns_tablet }} - 1) * {{ section.settings.card_gap_tablet }}px) / {{ section.settings.columns_tablet }});
    }
  }

  @media (min-width: 1024px) {
    .review-card-{{ section.id }} {
      min-width: calc((100% - ({{ section.settings.columns_desktop }} - 1) * {{ section.settings.card_gap_desktop }}px) / {{ section.settings.columns_desktop }});
    }
  }
  {% endif %}

  .review-card-{{ section.id }}:hover {
    box-shadow: {{ section.settings.card_hover_shadow }};
    transform: translateY({{ section.settings.card_hover_lift }}px);
  }

  .review-card-author-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: {{ section.settings.author_bottom_margin }}px;
  }

  .review-card-author-info-{{ section.id }} {
    flex: 1;
  }

  .review-card-author-{{ section.id }} h4 {
    font-size: {{ section.settings.author_name_size }}px;
    font-weight: {{ section.settings.author_name_weight }};
    color: {{ section.settings.author_name_color }};
    margin: 0 0 4px 0;
  }

  .review-card-verified-{{ section.id }} {
    font-size: {{ section.settings.verified_text_size }}px;
    color: {{ section.settings.verified_text_color }};
  }

  .review-card-author-image-{{ section.id }} {
    width: {{ section.settings.author_image_size }}px;
    height: {{ section.settings.author_image_size }}px;
    border-radius: {{ section.settings.author_image_radius }}%;
    object-fit: cover;
    order: {{ section.settings.author_image_order }};
  }

  .review-card-product-{{ section.id }} {
    width: 100%;
    height: {{ section.settings.product_image_height }}px;
    object-fit: cover;
    border-radius: {{ section.settings.product_image_radius }}px;
    margin-bottom: {{ section.settings.product_image_margin }}px;
  }

  .review-card-stars-{{ section.id }} {
    display: flex;
    gap: {{ section.settings.star_gap }}px;
    margin-bottom: {{ section.settings.stars_bottom_margin }}px;
  }

  .review-card-stars-{{ section.id }} svg {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    fill: {{ section.settings.star_color }};
  }

  .review-card-{{ section.id }} h3 {
    font-size: {{ section.settings.review_title_size }}px;
    font-weight: {{ section.settings.review_title_weight }};
    color: {{ section.settings.review_title_color }};
    margin: 0 0 {{ section.settings.title_bottom_margin }}px 0;
  }

  .review-card-{{ section.id }} .review-description {
    font-size: {{ section.settings.review_text_size }}px;
    color: {{ section.settings.review_text_color }};
    line-height: {{ section.settings.review_text_line_height }};
    margin: 0;
  }
</style>

<div class="reviews-section-{{ section.id }}">
  <div class="reviews-container-{{ section.id }}">
    
    <!-- Header Section -->
    <div class="reviews-header-{{ section.id }}">
      <div class="reviews-header-content-{{ section.id }}">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p>{{ section.settings.description }}</p>
        {% endif %}
      </div>
      
      {% if section.settings.show_navigation %}
      <div class="reviews-navigation-{{ section.id }}">
        <span class="reviews-counter-{{ section.id }}">
          <span class="current-slide">1</span> — <span class="total-slides">{{ section.blocks.size }}</span>
        </span>
        <div class="reviews-nav-buttons-{{ section.id }}">
          <button class="reviews-nav-btn-{{ section.id }} prev-btn" aria-label="Previous review">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="reviews-nav-btn-{{ section.id }} next-btn" aria-label="Next review">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
      {% endif %}
    </div>

    <!-- Reviews Container -->
    {% if section.settings.layout_type == 'grid' %}
      <div class="reviews-grid-{{ section.id }}">
        {% for block in section.blocks %}
          {% render 'review-card', block: block, section: section %}
        {% endfor %}
      </div>
    {% else %}
      <div class="reviews-carousel-{{ section.id }}">
        <div class="reviews-carousel-track-{{ section.id }}">
          {% for block in section.blocks %}
            {% render 'review-card', block: block, section: section %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>
</div>

{% if section.settings.layout_type == 'carousel' %}
<script>
(function() {
  const carousel = document.querySelector('.reviews-carousel-{{ section.id }}');
  const track = carousel.querySelector('.reviews-carousel-track-{{ section.id }}');
  const prevBtn = document.querySelector('.reviews-section-{{ section.id }} .prev-btn');
  const nextBtn = document.querySelector('.reviews-section-{{ section.id }} .next-btn');
  const currentSlideEl = document.querySelector('.reviews-section-{{ section.id }} .current-slide');
  const totalSlidesEl = document.querySelector('.reviews-section-{{ section.id }} .total-slides');
  
  const cards = track.querySelectorAll('.review-card-{{ section.id }}');
  const totalSlides = cards.length;
  let currentIndex = 0;
  let slidesToShow = {{ section.settings.columns_desktop }};
  
  function getSlidesToShow() {
    const width = window.innerWidth;
    if (width < 768) {
      return {{ section.settings.columns_mobile }};
    } else if (width < 1024) {
      return {{ section.settings.columns_tablet }};
    } else {
      return {{ section.settings.columns_desktop }};
    }
  }
  
  function getGap() {
    const width = window.innerWidth;
    if (width < 768) {
      return {{ section.settings.card_gap_mobile }};
    } else if (width < 1024) {
      return {{ section.settings.card_gap_tablet }};
    } else {
      return {{ section.settings.card_gap_desktop }};
    }
  }

  function updateCarousel() {
    slidesToShow = getSlidesToShow();
    const maxIndex = Math.max(0, totalSlides - slidesToShow);
    
    // Reset index if it exceeds max
    if (currentIndex > maxIndex) {
      currentIndex = maxIndex;
    }
    
    const cardWidth = cards[0].offsetWidth;
    const gap = getGap();
    const offset = -(currentIndex * (cardWidth + gap));
    track.style.transform = `translateX(${offset}px)`;
    
    currentSlideEl.textContent = currentIndex + 1;
    
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex >= maxIndex;
  }

  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      currentIndex--;
      updateCarousel();
    }
  });

  nextBtn.addEventListener('click', () => {
    const maxIndex = Math.max(0, totalSlides - getSlidesToShow());
    if (currentIndex < maxIndex) {
      currentIndex++;
      updateCarousel();
    }
  });

  updateCarousel();
  
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      updateCarousel();
    }, 250);
  });
})();
</script>
{% endif %}

